{
  "manifest_version": 3,
  "name": "YouTube URL Scraper",
  "version": "1.1",
  "description": "Select and download YouTube video URLs as a text file",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["*://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  }
}
